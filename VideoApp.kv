<MainScreen>:
    name: 'main'

    canvas.before:
        Color:
            rgba: 0, 0, 0, 0 # Black background color
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: root.width, root.height

    Image:
        id: img2
        size_hint: 1, 1
        fit_mode: "contain"

    Image:
        id: img1
        size_hint: 1, 1
        fit_mode: "contain"

    DPEAButton: #instructions
        id: info
        color: 0.937, 0.137, 0.235, 1#red
        text: "How to Play"
        font_size: "25sp"
        center_x: root.width * 0.2
        y: root.height * 0.20
        background_color: 1,0,0,0
        background_normal: ''
        size_hint: None,None
        size: 200, 100
        on_press: root.startUp()

    DPEAButton: #leaderboard
        id: leaderboard
        color: 0.0156, 0.4, 0.784, 1 #blue
        text: "Leaderboard"
        font_size: "25sp"
        center_x: root.width * 0.8
        y: root.height * 0.20
        background_color: 1,0,0,0
        background_normal: ''
        size_hint: None,None
        size: 200,100
        on_press: root.startUp()

    DPEAButton: #to start
        id: start_program
        color: 0.066, 0.682, 0.305, 1 #green
        text: "Start"
        font_size: "25sp"
        center_x: root.width * 0.5
        y: root.height * 0.20
        background_color: 1,0,0,0
        background_normal: ''
        size_hint: None,None
        size: 200,100
        on_press: root.startUp()

    Label:
        id: inverted_maze
        text: 'Inverted Maze'
        font_size: '70sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.95}
        color: 1, 1, 1, 1 #White label color
        outline_color: 0, 0, 0, 1  # Black outline color
        outline_width: 2
        bold: True


<GameScreen>:
    on_enter: root.start_video()
    name: 'game'

    canvas.before:
        Color:
            rgba: 0, 0, 0, 0 # Black background color
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: root.width, root.height

    Image:
        id: img2
        size_hint: 1, 1
        fit_mode: "contain"

    Image:
        id: img1
        size_hint: 1, 1
        fit_mode: "contain"

    Button:
        id: temp_but_2
        font_size: self.width * .3
        text: '>'
        size_hint: .1, .1
        pos_hint: {"center_x": 1, "center_y":0}
        color: 0, 0, 1, 0
        opacity: 0
        on_press: root.admin_action()

    Label:
        id: level_label
        text: '' #'Level 1'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.07, 'top': 0.95}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Image:
        id: right_arrow_symbol
        size_hint: (0.125, 0.125)
        source: 'right_arrow_symbol.png'
        pos_hint: {'center_x': 1000, 'center_y': 1000} #(0.93,0.495)

    Image:
        id: left_arrow_symbol
        size_hint: (0.125, 0.125)
        source: 'left_arrow_symbol.png'
        pos_hint: {'center_x': 1000, 'center_y': 1000} #(0.07,0.495)


    Label:
        id: insert_label
        text: ''
        font_size: '80sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.95}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 3

    Label:
        id: time_label
        text: ''
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.07, 'top': 0.95}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Label:
        id: vol_label
        text: ''
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.93, 'top': 0.1}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True


<LeftScreen>:
    on_enter: root.start_clock()
    name: 'left'
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0  # Black background color
        Rectangle:
            pos: self.pos
            size: self.size


    FloatLayout:
        size_hint: None, None

    Image:
        id: img2
        size_hint: (0.15, 0.15)
        source: 'enter_symbol.png'
        pos_hint: {'center_x': .5, 'center_y': .3}
        color: 1, 1, 1, 0.75

    Image:
        id: img3
        size_hint: (0.135, 0.135)
        source: 'backspace_symbol.png'
        pos_hint: {'center_x': .29, 'center_y': .3}
        color: 1, 1, 1, .5

    Image:
        id: right_arrow_symbol
        size_hint: (0.125, 0.125)
        source: 'right_arrow_symbol.png'
        pos_hint: {'center_x': 0.85, 'center_y': 0.3}

    Image:
        id: left_arrow_symbol
        size_hint: (0.125, 0.125)
        source: 'left_arrow_symbol.png'
        pos_hint: {'center_x': 0.15, 'center_y': 0.3}


    Label:
        id: letter_1
        text: ''
        font_size: '144sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.4, 'top': 0.35}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 0.75  # White outline color
        outline_width: 4
        bold: True

    Label:
        id: letter_2
        text: 'A'
        font_size: '180sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.35}
        color: 1, 0, 0, 1
        outline_color: 1, 1, 1, 1
        outline_width: 4
        bold: True

    Label:
        id: letter_3
        text: 'B'
        font_size: '144sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.6, 'top': 0.35}
        color: 1, 0, 0, 0.75
        outline_color: 1, 1, 1, 0.75
        outline_width: 4
        bold: True

    Label:
        id: letter_4
        text: ''
        font_size: '115.2sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.3, 'top': 0.35}
        color: 1, 0, 0, 0.5
        outline_color: 1, 1, 1, 0.5
        outline_width: 4
        bold: True

    Label:
        id: letter_5
        text: 'C'
        font_size: '115.2sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.7, 'top': 0.35}
        color: 1, 0, 0, 0.5
        outline_color: 1, 1, 1, 0.5
        outline_width: 4
        bold: True

    Label:
        id: pos_marker
        text: '^'
        font_size: '32sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'center_y': 0.2}
        color: 1, 0, 0, 1
        outline_color: 1, 1, 1, 1
        outline_width: 2
        bold: True

    Label:
        id: controls_label
        text: 'select      symbol when you are done'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': .5, 'center_y': .1}
        color: 1, 0, 0, 1
        outline_color: 1, 1, 1, 1
        outline_width: 2
        bold: True

    Image:
        id: label_e_symbol
        size_hint: (0.04, 0.04)
        source: 'enter_symbol.png'
        pos_hint: {'center_x': .38, 'center_y': .1}
        color: 1, 1, 1, 1

    Label:
        id: score_label
        text: 'Enter your name'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': .5, "center_y":0.75}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Label:
        id: name_label
        text: ''
        font_size: '75sp'
        size_hint: (None, None)
        pos_hint: {'center_x': .5, "center_y":0.5}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Label:
        id: time_label
        text: ''
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': .5, "center_y":0.85}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True



<RightScreen>:
    on_enter: root.update_high_scores(); root.start_clock()
    name: 'right'

    canvas.before:
        Color:
            rgba: 0, 0, 0, 1  # Black background color
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: None, None

<Instructions>:
    name: 'instructions'

    canvas.before:
        Color:
            rgba: 0, 0, 0, 0 # Black background color
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: root.width, root.height

    Image:
        id: img2
        size_hint: 1, 1
        fit_mode: "contain"

    Image:
        id: img1
        size_hint: 1, 1
        fit_mode: "contain"

    Label:
        id: title
        text: 'Instructions'
        font_size: '70sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.95}
        color: 1, 1, 1, 1 #White label color
        outline_color: 0, 0, 0, 1  # Black outline color
        outline_width: 2
        bold: True

    Label:
        id: first_sentence
        text: 'Hello, welcome to the Inverted Maze!'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.80}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Label:
        id: second_sentence
        text: 'To play the game, use the handle bars to move the ball in the maze.'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.70}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Label:
        id: third_sentence
        text: 'A camera above shows you an overview of the ball, so keep looking at this screen.'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.60}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Label:
        id: fourth_sentence
        text: 'At the end of each level, record your name by using the buttons.'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.50}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Label:
        id: fifth_sentence
        text: 'Can you get the fastest time for each level?'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.40}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    Label:
        id: sixth_sentence
        text: 'Have fun :)'
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.30}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1  # White outline color
        outline_width: 2
        bold: True

    DPEAButton:
        id: return_home
        color: 0.066, 0.682, 0.305, 1 #green
        text: "Back"
        center_x: root.width * 0.5
        y: root.height * 0.10
        background_color: 1,0,0,0
        background_normal: ''
        size_hint: None,None
        size: 200,100
        on_press: root.home()


<Leaderboard>:
