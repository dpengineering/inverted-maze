    name: 'leaderboard'

    canvas.before:
        Color:
            rgba: 0,0,0,0  # White background color
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: root.width, root.height

    Image:
        id: img2
        size_hint: 1, 1
        fit_mode: "contain"

    Image:
        id: img1
        size_hint: 1, 1
        fit_mode: "contain"

    Label:
        id: the_title
        text: "Leaderboard"
        font_size: '70sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.5, 'top': 0.95}
        color: 1, 1, 1, 1 #White label color
        outline_color: 0, 0, 0, 1  # Black outline color
        outline_width: 2
        bold: True

    Label:
        id: lvl_one_high_score
        text: ''
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.2, 'top': 0.75}
        color: 0.937, 0.137, 0.235, 1 #red
        outline_color: 1, 1, 1, 1
        outline_width: 2
        bold: True

    Label:
        id: lvl_two_high_score
        text: ''
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.2, 'top': 0.65}
        color: 0.937, 0.137, 0.235, 1 #red
        outline_color: 1, 1, 1, 1
        outline_width: 2
        bold: True

    Label:
        id: lvl_three_high_score
        text: ''
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.2, 'top': 0.55}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1
        outline_width: 2
        bold: True

    Label:
        id: lvl_four_high_score
        text: ''
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.2, 'top': 0.45}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1
        outline_width: 2
        bold: True

    Label:
        id: lvl_five_high_score
        text: ''
        font_size: '50sp'
        size_hint: (None, None)
        pos_hint: {'center_x': 0.2, 'top': 0.35}
        color: 0.937, 0.137, 0.235, 1#red
        outline_color: 1, 1, 1, 1
        outline_width: 2
        bold: True

    DPEAButton:
        id: back_home
        color: 0.066, 0.682, 0.305, 1 #green
        text: "Back"
        center_x: root.width * 0.5
        y: root.height * 0.10
        background_color: 1,0,0,0
        background_normal: ''
        size_hint: None,None
        size: 200,100
        on_press: root.back_to_home()